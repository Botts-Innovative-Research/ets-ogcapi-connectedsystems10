{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Integer pair used for specifying a count range",
  "type": "object",
  "allOf": [
    {
      "$ref": "https://csapi-compliance.local/schemas/connected-systems-shared/swecommon/schemas/json/AbstractSimpleComponent.json"
    },
    {
      "properties": {
        "type": {
          "const": "CountRange"
        },
        "constraint": {
          "$ref": "https://csapi-compliance.local/schemas/connected-systems-shared/swecommon/schemas/json/basicTypes.json#/$defs/AllowedValues"
        },
        "nilValues": {
          "$ref": "https://csapi-compliance.local/schemas/connected-systems-shared/swecommon/schemas/json/basicTypes.json#/$defs/NilValuesText"
        },
        "value": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "integer"
          }
        }
      },
      "required": [
        "type",
        "definition",
        "label"
      ]
    }
  ],
  "$id": "https://csapi-compliance.local/schemas/connected-systems-shared/swecommon/schemas/json/CountRange.json"
}
