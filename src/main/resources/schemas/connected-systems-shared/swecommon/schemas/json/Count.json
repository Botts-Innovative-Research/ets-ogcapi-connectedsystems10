{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Scalar component with integer representation used for a discrete counting value",
  "type": "object",
  "allOf": [
    {
      "$ref": "https://csapi-compliance.local/schemas/connected-systems-shared/swecommon/schemas/json/AbstractSimpleComponent.json"
    },
    {
      "properties": {
        "type": {
          "const": "Count"
        },
        "constraint": {
          "$ref": "https://csapi-compliance.local/schemas/connected-systems-shared/swecommon/schemas/json/basicTypes.json#/$defs/AllowedValues"
        },
        "nilValues": {
          "$ref": "https://csapi-compliance.local/schemas/connected-systems-shared/swecommon/schemas/json/basicTypes.json#/$defs/NilValuesInteger"
        },
        "value": {
          "type": "integer"
        }
      },
      "required": [
        "type",
        "definition",
        "label"
      ]
    }
  ],
  "$id": "https://csapi-compliance.local/schemas/connected-systems-shared/swecommon/schemas/json/Count.json"
}
