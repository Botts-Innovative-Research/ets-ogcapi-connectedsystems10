{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "commandFormat": {
      "const": "application/x-protobuf"
    },
    "messageSchema": {
      "description": "Protobuf schema provided as a string or as a link to an external proto file",
      "oneOf": [
        {
          "title": "Inline schema",
          "type": "string",
          "minLength": 1
        },
        {
          "title": "Link to external file",
          "$ref": "https://csapi-compliance.local/schemas/connected-systems-2/common/commonDefs.json#/$defs/Link"
        }
      ]
    }
  },
  "required": [
    "commandFormat",
    "messageSchema"
  ],
  "$id": "https://csapi-compliance.local/schemas/connected-systems-2/json/commandSchemaProtobuf.json"
}
