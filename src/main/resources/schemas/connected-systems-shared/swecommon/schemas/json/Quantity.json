{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Scalar component with decimal representation and a unit of measure used to store value of a continuous quantity",
  "type": "object",
  "allOf": [
    {
      "$ref": "https://csapi-compliance.local/schemas/connected-systems-shared/swecommon/schemas/json/AbstractSimpleComponent.json"
    },
    {
      "properties": {
        "type": {
          "const": "Quantity"
        },
        "uom": {
          "description": "Unit of measure used to express the value of this data component",
          "$ref": "https://csapi-compliance.local/schemas/connected-systems-shared/swecommon/schemas/json/basicTypes.json#/$defs/UnitReference"
        },
        "constraint": {
          "$ref": "https://csapi-compliance.local/schemas/connected-systems-shared/swecommon/schemas/json/basicTypes.json#/$defs/AllowedValues"
        },
        "nilValues": {
          "$ref": "https://csapi-compliance.local/schemas/connected-systems-shared/swecommon/schemas/json/basicTypes.json#/$defs/NilValuesNumber"
        },
        "value": {
          "$ref": "https://csapi-compliance.local/schemas/connected-systems-shared/swecommon/schemas/json/basicTypes.json#/$defs/NumberOrSpecial"
        }
      },
      "required": [
        "type",
        "definition",
        "label",
        "uom"
      ]
    }
  ],
  "$id": "https://csapi-compliance.local/schemas/connected-systems-shared/swecommon/schemas/json/Quantity.json"
}
