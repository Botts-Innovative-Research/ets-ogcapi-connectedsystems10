{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Scalar component used to represent a categorical value as a simple token identifying a term in a code space",
  "type": "object",
  "allOf": [
    {
      "$ref": "https://csapi-compliance.local/schemas/connected-systems-shared/swecommon/schemas/json/AbstractSimpleComponent.json"
    },
    {
      "properties": {
        "type": {
          "const": "Category"
        },
        "codeSpace": {
          "description": "Name of the dictionary where the possible values for this component are listed and defined",
          "type": "string",
          "format": "uri"
        },
        "constraint": {
          "$ref": "https://csapi-compliance.local/schemas/connected-systems-shared/swecommon/schemas/json/basicTypes.json#/$defs/AllowedTokens"
        },
        "nilValues": {
          "$ref": "https://csapi-compliance.local/schemas/connected-systems-shared/swecommon/schemas/json/basicTypes.json#/$defs/NilValuesText"
        },
        "value": {
          "type": "string"
        }
      },
      "required": [
        "type",
        "definition",
        "label"
      ]
    }
  ],
  "$id": "https://csapi-compliance.local/schemas/connected-systems-shared/swecommon/schemas/json/Category.json"
}
