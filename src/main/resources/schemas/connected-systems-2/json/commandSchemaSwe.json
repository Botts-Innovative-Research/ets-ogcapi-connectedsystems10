{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "commandFormat": {
      "type": "string"
    },
    "recordSchema": {
      "$ref": "https://csapi-compliance.local/schemas/connected-systems-2/common/sweCommonDefs.json#/$defs/AnyComponent"
    },
    "encoding": {}
  },
  "required": [
    "commandFormat",
    "recordSchema",
    "encoding"
  ],
  "oneOf": [
    {
      "title": "SWE JSON",
      "properties": {
        "commandFormat": {
          "const": "application/swe+json"
        },
        "encoding": {
          "$ref": "https://csapi-compliance.local/schemas/connected-systems-2/common/sweCommonDefs.json#/$defs/JSONEncoding"
        }
      }
    },
    {
      "title": "SWE Text",
      "properties": {
        "commandFormat": {
          "const": "application/swe+text"
        },
        "encoding": {
          "$ref": "https://csapi-compliance.local/schemas/connected-systems-2/common/sweCommonDefs.json#/$defs/TextEncoding"
        }
      }
    },
    {
      "title": "SWE CSV",
      "properties": {
        "commandFormat": {
          "const": "application/swe+csv"
        },
        "encoding": {
          "allOf": [
            {
              "$ref": "https://csapi-compliance.local/schemas/connected-systems-2/common/sweCommonDefs.json#/$defs/TextEncoding"
            },
            {
              "properties": {
                "tokenSeparator": {
                  "const": ","
                },
                "blockSeparator": {
                  "const": "\n"
                }
              }
            }
          ]
        }
      }
    },
    {
      "title": "SWE Binary",
      "properties": {
        "commandFormat": {
          "const": "application/swe+binary"
        },
        "encoding": {
          "$ref": "https://csapi-compliance.local/schemas/connected-systems-2/common/sweCommonDefs.json#/$defs/BinaryEncoding"
        }
      }
    }
  ],
  "$id": "https://csapi-compliance.local/schemas/connected-systems-2/json/commandSchemaSwe.json"
}
